;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TowerBloxx"
run/main_scene="uid://bgtpqob1qhrqc"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://qargmxoa40qi"

[autoload]

SceneTransition="*uid://ms4pxji4oygs"
